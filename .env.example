# App
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:5173

# Database (MySQL)
DATABASE_URL=mysql://root:root@localhost:3306/app_db

# Auth / Security
JWT_SECRET=change_me_to_a_long_random_secret

# External APIs
BUILT_IN_FORGE_API_KEY=your_forge_api_key_here

# Optional AWS (if used in uploads/storage)
AWS_ACCESS_KEY_ID=AKIA_EXAMPLE
AWS_SECRET_ACCESS_KEY=example_secret_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=vidaso-dev-bucket
